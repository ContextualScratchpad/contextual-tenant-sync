# Contextual Platform — Snapshot Exporter Configuration
# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed to the repo.
#
# For CI (GitHub Actions), set these as repository secrets/variables instead.
# See the README → "Creating a new tenant repo" for the full setup sequence.

# ── Required ────────────────────────────────────────────

# Client ID from the Contextual platform API key settings.
# Obtain via: Platform UI → Settings → API Keys → Create Key
CTXL_CLIENT_ID=

# Client Secret from the Contextual platform API key settings.
# Treat this like a password — never commit it.
CTXL_CLIENT_SECRET=

# Your tenant ID (the subdomain segment of your platform URLs).
# Example: if your platform URL is https://native-object.acme.my.dev.contextual.io
# then your tenant ID is "acme"
CTXL_TENANT_ID=

# ── Optional ────────────────────────────────────────────

# Platform silo. One of: dev, prod, qa
# Defaults to "dev" if not set.
CTXL_SILO=dev
