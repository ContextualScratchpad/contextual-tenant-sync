# ⚠️  LOCAL DEVELOPMENT ONLY
# -------------------------------------------------------------------
# This file is for running export.js locally to test against a real
# tenant. It is NOT the recommended approach for tenant snapshot repos.
#
# For actual tenant snapshot repos, credentials and config MUST be
# set as GitHub Actions secrets and repository variables:
#
#   Secrets (sensitive):
#     gh secret set CTXL_CLIENT_ID     --repo <org>/<repo>
#     gh secret set CTXL_CLIENT_SECRET --repo <org>/<repo>
#
#   Variables (non-sensitive):
#     gh variable set CTXL_TENANT_ID --body "<tenant-id>" --repo <org>/<repo>
#     gh variable set CTXL_SILO      --body "<silo>"      --repo <org>/<repo>
#
# The sync workflow reads from those GitHub values automatically.
# You should never need a .env file in a tenant snapshot repo.
# -------------------------------------------------------------------
#
# To test locally:
#   cp .env.example .env
#   # fill in the values below
#   node export.js --out ./test-snapshot

# ── Required ────────────────────────────────────────────────────────

# Client ID from the Contextual platform API key settings.
# Obtain via: Platform UI → Settings → API Keys → Create Key
CTXL_CLIENT_ID=

# Client Secret from the Contextual platform API key settings.
# Treat this like a password — never commit it.
CTXL_CLIENT_SECRET=

# Your tenant ID (the subdomain segment of your platform URLs).
# Example: if your platform URL is https://native-object.acme.my.contextual.io
# then your tenant ID is "acme"
CTXL_TENANT_ID=

# ── Optional ────────────────────────────────────────────────────────

# Platform silo. One of: prod, dev, qa
# Defaults to "prod" if not set.
CTXL_SILO=prod
