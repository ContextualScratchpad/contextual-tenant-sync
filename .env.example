# Contextual Platform — Snapshot Exporter Configuration
# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed to the repo.
#
# For CI (GitHub Actions), set these as repository secrets instead.
# See README.md → "Step 5: Configure GitHub Actions Secrets"

# ── Required ────────────────────────────────────────────

# API key issued by the Contextual platform.
# Obtain via: Platform UI → Settings → API Keys → Create Key
CTXL_API_KEY=

# Your tenant ID (the subdomain segment of your platform URLs).
# Example: if your platform URL is https://native-object.acme.my.dev.contextual.io
# then your tenant ID is "acme"
CTXL_TENANT_ID=

# ── Optional ────────────────────────────────────────────

# Platform silo. One of: dev, prod
# Defaults to "dev" if not set.
CTXL_SILO=dev
